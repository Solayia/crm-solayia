generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  COMMERCIAL
  READONLY
}

enum ProspectStatus {
  NEW
  CONTACTED
  QUALIFIED
  UNQUALIFIED
  CONVERTED
  LOST
}

enum InteractionType {
  CALL
  EMAIL
  MEETING
  NOTE
  TASK_DONE
  OTHER
}

model User {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique
  passwordHash  String    @map("password_hash")
  fullName      String    @map("full_name")
  role          UserRole  @default(COMMERCIAL)
  isActive      Boolean   @default(true) @map("is_active")
  lastLoginAt   DateTime? @map("last_login_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  auditLogs     AuditLog[]
  prospects     Prospect[]   @relation("ProspectOwner")

  @@map("users")
}

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String?  @map("user_id") @db.Uuid
  action      String
  entityType  String   @map("entity_type")
  entityId    String?  @map("entity_id") @db.Uuid
  changes     Json?
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at")

  user        User?    @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([userId, createdAt])
  @@map("audit_log")
}

model Prospect {
  id              String          @id @default(uuid()) @db.Uuid
  companyName     String          @map("company_name")
  industry        String?
  website         String?
  street          String?
  city            String?
  postalCode      String?         @map("postal_code")
  status          ProspectStatus  @default(NEW)
  source          String?
  notes           String?         @db.Text
  ownerId         String          @map("owner_id") @db.Uuid

  // Phone fields
  mobilePhone     String?         @map("mobile_phone")
  fixedPhone      String?         @map("fixed_phone")
  phone           String?
  email           String?

  // Tier & scoring — Phase 5 ready
  tier            String?         @default("D")
  score           Int?            @default(0)

  // Google enrichment from Apify
  googleScore     Float?          @map("google_score")
  googleReviews   Int?            @map("google_reviews")
  googleMapsUrl   String?         @map("google_maps_url")
  categories      String[]        @default([])
  categoryName    String?         @map("category_name")

  importBatchId   String?         @map("import_batch_id") @db.Uuid

  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  // Relations
  owner           User            @relation("ProspectOwner", fields: [ownerId], references: [id])
  contacts        ProspectContact[]
  interactions    Interaction[]

  @@index([status])
  @@index([tier])
  @@index([ownerId])
  @@index([city])
  @@map("prospects")
}

model ProspectContact {
  id          String   @id @default(uuid()) @db.Uuid
  prospectId  String   @map("prospect_id") @db.Uuid
  fullName    String   @map("full_name")
  email       String?
  phone       String?
  role        String?
  isPrimary   Boolean  @default(false) @map("is_primary")
  createdAt   DateTime @default(now()) @map("created_at")

  prospect    Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  @@map("prospect_contacts")
}

model Interaction {
  id          String          @id @default(uuid()) @db.Uuid
  prospectId  String?         @map("prospect_id") @db.Uuid
  userId      String          @map("user_id") @db.Uuid
  type        InteractionType
  subject     String?
  notes       String          @db.Text
  occurredAt  DateTime        @default(now()) @map("occurred_at")
  createdAt   DateTime        @default(now()) @map("created_at")

  prospect    Prospect?       @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  @@index([prospectId])
  @@index([occurredAt])
  @@map("interactions")
}
